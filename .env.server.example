# Backuper — конфигурация СЕРВЕРА (раздел 18.1 ТЗ).
# Скопируйте в /etc/backuper/.env, права 600, владелец — пользователь backuper.
# Длительности: 30s, 5m, 1h, 24h. Размеры: 1MiB, 100MB или в байтах.

# --- Адрес клиента в LAN (инициатор — сервер) ---
CLIENT_HOST=192.168.1.50
CLIENT_PORT=9000

# --- TLS / mTLS (раздел 6) ---
TLS_CERT_FILE=/etc/backuper/certs/server.crt
TLS_KEY_FILE=/etc/backuper/certs/server.key
TLS_CA_FILE=/etc/backuper/certs/ca.crt
TLS_MIN_VERSION=1.2

# --- Пароли (обмен паролями, ≥24 символа). ---
# server.OWN_PASSWORD должен совпадать с client.PEER_PASSWORD и наоборот.
OWN_PASSWORD=ЗАМЕНИТЕ-пароль-сервера-не-короче-24-символов
PEER_PASSWORD=ЗАМЕНИТЕ-пароль-клиента-не-короче-24-символов

# --- Директории сервера ---
STORAGE_DIR=/srv/backuper/storage
TRASH_DIR=/srv/backuper/trash
TEMP_DIR=/srv/backuper/temp

# --- Корзина (раздел 11) ---
TRASH_RETENTION_DAYS=10
TRASH_CLEANUP_INTERVAL=24h

# --- Сверка и передача ---
SYNC_INTERVAL=1h
SYNC_MAX_PASSES=3
PARALLEL_TRANSFERS=4
BANDWIDTH_LIMIT=0
CHUNK_SIZE=1MiB
# MAX_FRAME_BYTES=16MiB
# Дельта-передача изменённых файлов (экономит трафик при дозаписи/правках на месте).
# DELTA_MIN_SIZE=1MiB    # применять дельту для изменённых файлов не меньше этого размера; 0 — выключить
# DELTA_BLOCK_SIZE=1MiB  # размер блока сравнения
# LIST_BATCH_SIZE=10000

# --- Повторы и тайм-ауты (раздел 14, 5.7) ---
RETRY_COUNT=3
RETRY_DELAY=1m
MTIME_TOLERANCE=2s
CONNECT_TIMEOUT=30s
IO_TIMEOUT=60s
HEALTHCHECK_INTERVAL=30s

# --- Права на сохраняемые файлы (раздел 7.6) ---
SAVE_FILE_PERMS=0666
SAVE_DIR_PERMS=0777

# --- Пороги алертов (раздел 15) ---
ALERT_MASS_DELETE_THRESHOLD=100
DISK_ALERT_THRESHOLD=90
ALERT_AGGREGATION_WINDOW=60s

# --- Почта (SMTP, раздел 15.1). SMTP_SECURITY: none | starttls | tls ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=backuper@example.com
SMTP_PASSWORD=ЗАМЕНИТЕ-пароль-smtp
SMTP_FROM=backuper@example.com
SMTP_TO=admin1@example.com,admin2@example.com
SMTP_SECURITY=starttls

# --- Логи и аудит (раздел 16). LOG_FORMAT: text | json ---
LOG_LEVEL=INFO
LOG_DIR=/var/log/backuper
LOG_MAX_SIZE=100
LOG_MAX_FILES=7
LOG_MAX_AGE=0
LOG_FORMAT=text
AUDIT_LOG=/var/log/backuper/audit.jsonl

# --- Состояние и блокировка (раздел 17) ---
STATE_DB=/var/lib/backuper/state.db
LOCK_FILE=/var/lib/backuper/backuper.lock

# --- Часовой пояс ---
TIMEZONE=Europe/Moscow
