# Backuper — конфигурация КЛИЕНТА (раздел 18.2 ТЗ).
# Скопируйте в /etc/backuper/.env, права 600, владелец — пользователь backuper.

# Слушатель (клиент — служба, слушающая TLS-порт)
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9000

# TLS / mTLS (раздел 6). SAN в client.crt = адрес этого клиента (CLIENT_HOST у сервера).
TLS_CERT_FILE=/etc/backuper/certs/client.crt
TLS_KEY_FILE=/etc/backuper/certs/client.key
TLS_CA_FILE=/etc/backuper/certs/ca.crt
TLS_MIN_VERSION=1.2

# Пароли (зеркально серверу)
OWN_PASSWORD=ЗАМЕНИТЕ-пароль-клиента-не-короче-24-символов
PEER_PASSWORD=ЗАМЕНИТЕ-пароль-сервера-не-короче-24-символов

# --- Источник бэкапа (он же цель восстановления) ---
BACKUP_DIR=/data

# --- Фильтры (glob, через запятую). По умолчанию пусто. ---
INCLUDE_PATTERNS=
EXCLUDE_PATTERNS=*.tmp,*.lock,~$*

# --- Передача ---
BANDWIDTH_LIMIT=0
CHUNK_SIZE=1MiB
IO_TIMEOUT=60s
MAX_CONNECTIONS=8
# MAX_FRAME_BYTES=16MiB

# --- Права при восстановлении (restore) ---
SAVE_FILE_PERMS=0666
SAVE_DIR_PERMS=0777

# --- Логи и аудит (раздел 16) ---
LOG_LEVEL=INFO
LOG_DIR=/var/log/backuper
LOG_MAX_SIZE=100
LOG_MAX_FILES=7
LOG_MAX_AGE=0
LOG_FORMAT=text
AUDIT_LOG=/var/log/backuper/audit.jsonl

# --- Часовой пояс ---
TIMEZONE=Europe/Moscow
